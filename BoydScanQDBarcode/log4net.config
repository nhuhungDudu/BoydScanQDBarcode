<?xml version="1.0" encoding="utf-8"?>
<log4net>

	<!-- ScanQRCable log -->
	<appender name="ScanQRCableAppender" type="log4net.Appender.RollingFileAppender">
		<file value="Logs/ScanQRCable/ScanQRCable_" />
		<appendToFile value="true" />
		<rollingStyle value="Date" />
		<datePattern value="yyyyMMdd'.log'" />
		<staticLogFileName value="false" />
		<layout type="log4net.Layout.PatternLayout">
			<conversionPattern value="[%date{yyyy-MM-dd HH:mm:ss}] [%-5level] - %message%newline" />
		</layout>
	</appender>
	<!-- Liên kết từng logger riêng -->

	<logger name="ScanQRCableLogger">
		<level value="DEBUG" />
		<appender-ref ref="ScanQRCableAppender" />
	</logger>
	<!-- Root logger (tùy chọn, để chung) -->
	<root>
		<level value="INFO" />
	</root>
</log4net>

