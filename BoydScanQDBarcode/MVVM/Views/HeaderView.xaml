<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BoydScanQDBarcode.MVVM.Views"
             xmlns:ViewModels="clr-namespace:BoydScanQDBarcode.ViewModels" x:Class="BoydScanQDBarcode.MVVM.Views.HeaderView"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="1000">
    <UserControl.DataContext>
        <ViewModels:HeaderVM/>
    </UserControl.DataContext>
    <Border Background="{StaticResource PrimaryBrush}" Padding="20,10" CornerRadius="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" Margin="20,0" CornerRadius="10">
                <Image Source="/Resources/Capture.PNG" Stretch="Uniform"/>
            </Border>

            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Scan QD Barcode" Foreground="White" FontWeight="Bold" FontSize="24" HorizontalAlignment="Center"/>
                <TextBlock Foreground="White" HorizontalAlignment="Center" Opacity="0.8"><Run Text="{Binding AppVersion}"/><Run Text=" "/><Run Text=" | "/><Run Text=" "/><Run Text="{Binding DateNow}"/><Run Text=" "/><Run Text=" | "/><Run Text=" "/><Run x:Name="CurrentTimeRun" Text="{Binding TimeNow}"/></TextBlock>
            </StackPanel>

            <Grid Grid.Column="2" Width="300" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="55"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="CPU:" Style="{StaticResource TextBlockNormal}" Foreground="White" Margin="0,0,10,0"/>
                <Grid Grid.Row="0" Grid.Column="1" Margin="0,5">
                    <Border BorderThickness="1" BorderBrush="Gray" Background="White" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" x:Name="cpuUsedColumn" />
                            <ColumnDefinition Width="*" x:Name="cpuUnusedColumn" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="cpuUsedBackground" Grid.Column="0" Background="#28A745" />
                    </Grid>
                </Grid>
                <TextBlock Grid.Column="2" x:Name="CpuUsageText" Text="0.00%" Style="{StaticResource TextBlockNormal}" Foreground="White" Margin="15,0,0,0"/>

                <TextBlock Grid.Row="1" Text="RAM:" Style="{StaticResource TextBlockNormal}" Foreground="White" Margin="0,0,10,0"/>
                <Grid Grid.Row="1" Grid.Column="1" Margin="0,5">
                    <Border BorderThickness="1" BorderBrush="Gray" Background="White" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" x:Name="memUsedColumn" />
                            <ColumnDefinition Width="*" x:Name="memUnusedColumn" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="memUsedBackground" Grid.Column="0" Background="#28A745" />
                    </Grid>
                </Grid>
                <TextBlock Grid.Row="1" Grid.Column="2" x:Name="MemUsageText" Text="0GB/0GB (0%)" Style="{StaticResource TextBlockNormal}" Foreground="White" Margin="15,0,0,0"/>

                <TextBlock Grid.Row="2" Text="DISK C:" Style="{StaticResource TextBlockNormal}" Foreground="White" Margin="0,0,10,0"/>

                <Grid Grid.Row="2" Grid.Column="1" Margin="0,5">
                    <Border BorderThickness="1" BorderBrush="Gray" Background="White" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" x:Name="diskCUsedColumn" />
                            <ColumnDefinition Width="*" x:Name="diskCUnusedColumn" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="diskCUsedBackground" Grid.Column="0" Background="#28A745" />
                    </Grid>
                </Grid>

                <TextBlock Grid.Row="2" Grid.Column="2" x:Name="diskCText" Text="0GB/0GB (0%)" Style="{StaticResource TextBlockNormal}" Foreground="White" Margin="15,0,0,0"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>